        --cinza-borda: #dbe3ee;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        color: var(--texto);
        background: var(--branco);
        line-height: 1.6;
      }

      .container {
        width: min(1100px, 92%);
        margin: 0 auto;
      }

      header {
        background: var(--branco);
        border-bottom: 1px solid var(--cinza-borda);
        padding: 18px 0;
      }

      .topo {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .logo {
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--azul);
      }

      nav a {
        margin-left: 20px;
        text-decoration: none;
        color: var(--azul);
        font-weight: 500;
      }

      .hero {
        padding: 80px 0;
        background: var(--azul-claro);
      }

