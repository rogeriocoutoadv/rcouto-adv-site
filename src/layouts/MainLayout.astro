---
const { title = 'Rogerio Couto Advocacia', description = 'Direito Bancário, Empresarial e Tributário em Joinville e região.' } = Astro.props;
---

<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style>
      :root {
        --azul: #0f2747;
        --azul-claro: #f4f7fb;
        --texto: #1f2937;
        --branco: #ffffff;
        --verde: #1fa855;
        --cinza-borda: #dbe3ee;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        color: var(--texto);
        background: var(--branco);
        line-height: 1.6;
      }

      .container {
        width: min(1100px, 92%);
        margin: 0 auto;
      }

      header {
        background: var(--branco);
        border-bottom: 1px solid var(--cinza-borda);
        padding: 18px 0;
      }

      .topo {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .logo a {
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--azul);
        text-decoration: none;
      }

      nav {
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
      }

      nav a {
        text-decoration: none;
        color: var(--azul);
        font-weight: 500;
      }

      main {
        padding: 70px 0;
      }

      h1 {
        font-size: 2.3rem;
        color: var(--azul);
        margin-bottom: 18px;
        line-height: 1.2;
      }

      h2, h3 {
        color: var(--azul);
        margin: 28px 0 12px;
      }

      p {
        margin-bottom: 16px;
      }

      ul {
        margin: 0 0 18px 20px;
      }

      li {
        margin-bottom: 10px;
      }

      blockquote {
        margin: 24px 0;
        padding: 18px 20px;
        border-left: 4px solid var(--verde);
        background: var(--azul-claro);
        border-radius: 8px;
      }

      .pagina {
        max-width: 850px;
      }

      .botao {
        display: inline-block;
        background: var(--verde);
        color: white;
        padding: 12px 22px;
        text-decoration: none;
        border-radius: 8px;
        font-weight: 600;
        margin-top: 10px;
      }

      footer {
        background: var(--azul);
        color: var(--branco);
        padding: 30px 0;
        font-size: 0.95rem;
      }

      @media (max-width: 768px) {
        .topo {
          flex-direction: column;
          gap: 14px;
        }

        nav {
          justify-content: center;
        }

        h1 {
          font-size: 2rem;
        }
      }
    </style>
  </head>

  <body>
    <header>
      <div class="container topo">
        <div class="logo">
          <a href="/">Rogerio Couto Advocacia</a>
        </div>
        <nav>
          <a href="/">Home</a>
          <a href="/sobre">Sobre</a>
          <a href="/bancario">Direito Bancário</a>
          <a href="/empresarial">Direito Empresarial</a>
          <a href="/fiscal">Execução Fiscal</a>
          <a href="/contato">Contato</a>
          <a href="/ebook">E-book</a>
        </nav>
      </div>
    </header>

    <main>
      <div class="container pagina">
        <slot />
      </div>
    </main>

    <footer>
      <div class="container">
        Rogerio Couto Advocacia | OAB/SC 31.283 | Joinville/SC | WhatsApp: (47) 99749-5458
      </div>
    </footer>
  </body>
</html>
